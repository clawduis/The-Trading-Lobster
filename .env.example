# ─── Hyperliquid ───────────────────────────────────────────────────────────────
# Your Ethereum wallet private key (used to sign orders on Hyperliquid)
# Generate a fresh wallet specifically for this — never use your main wallet
HYPERLIQUID_PRIVATE_KEY=0xyour_private_key_here

# Your wallet address (checksummed)
HYPERLIQUID_WALLET_ADDRESS=0xYourWalletAddress

# Set to "true" for Hyperliquid testnet, "false" for mainnet
USE_TESTNET=true

# ─── Hardware ──────────────────────────────────────────────────────────────────
# Serial port where your bio-amp/Arduino is connected
# Linux/Mac: /dev/ttyUSB0  or  /dev/ttyACM0
# Windows:   COM3
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=115200

# ─── Alerts (optional) ─────────────────────────────────────────────────────────
# Telegram bot token + chat ID for trade alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
